{
  "name": "ai-db-client",
  "version": "0.0.4",
  "description": "Open-source AI-native database client with MCP server support",
  "license": "MIT",
  "author": "tomsean <tom_sean@outlook.com>",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "cross-env ELECTRON_RUN_AS_NODE= electron-vite dev",
    "build": "electron-vite build",
    "dist": "electron-vite build && electron-builder --publish never",
    "dist:mac": "electron-vite build && electron-builder --mac --publish never",
    "dist:win": "electron-vite build && electron-builder --win --publish never",
    "dist:linux": "electron-vite build && electron-builder --linux --publish never",
    "preview": "cross-env ELECTRON_RUN_AS_NODE= electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "typecheck:main": "tsc --noEmit -p tsconfig.main.json",
    "typecheck:renderer": "tsc --noEmit -p tsconfig.renderer.json",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "rebuild": "cross-env ELECTRON_RUN_AS_NODE= electron-rebuild -f -w better-sqlite3 -w keytar",
    "prepare": "husky"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.10.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.4.4",
    "electron-store": "^11.0.2",
    "ioredis": "^5.11.1",
    "keytar": "^7.9.0",
    "lucide-react": "^1.18.0",
    "monaco-editor": "^0.55.1",
    "mysql2": "^3.22.5",
    "node-sql-parser": "^5.4.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sql-formatter": "^15.8.1",
    "zustand": "^5.0.14"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "keytar"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.39.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mysql": "^2.15.27",
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^10.1.0",
    "cross-env-shell": "^7.0.3",
    "electron": "^42.4.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
